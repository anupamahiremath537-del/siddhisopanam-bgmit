# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  AUTHENTICATION & SECURITY
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

JWT_SECRET=your_jwt_secret_key_min_32_chars
ORGANIZER_SECRET_CODE=your_secret_organizer_code

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  APPLICATION URLs
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

APP_URL=http://localhost:3000
RESET_PASSWORD_URL=http://localhost:3000/reset-password.html
PORT=3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  EMAIL CONFIGURATION (Nodemailer)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
ADMIN_EMAIL=admin@eventvault.org
FROM_EMAIL=noreply@eventvault.org

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  FIREBASE (if still using for other services)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  GOOGLE AI (Gemini)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

GOOGLE_AI_API_KEY=your_google_ai_api_key

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  DEPLOYMENT (Cloud Run / Firebase)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

NODE_ENV=development
FUNCTION_NAME=api

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  NOTES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# To get these values:
#
# SUPABASE_SERVICE_ROLE_KEY:
#   1. Go to https://app.supabase.com
#   2. Select your EventVault project
#   3. Settings → API → Service Role Key
#   4. Copy the full key
#
# SMTP_PASSWORD (Gmail):
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Select Mail and Windows Computer
#   4. Copy the 16-character password
#
# GOOGLE_AI_API_KEY:
#   1. Go to https://makersuite.google.com/app/apikey
#   2. Create a new API key
#   3. Copy it here
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

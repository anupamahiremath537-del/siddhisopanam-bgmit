{
  "name": "event-scheduling-volunteer-app",
  "version": "1.0.0",
  "description": "Event Scheduling and Volunteer Sign-up Application",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate:firestore-to-supabase": "node scripts/migrate_firestore_to_supabase.js",
    "migrate:create-tables": "node scripts/create_supabase_tables.js"
  },
  "nodemonConfig": {
    "ignore": [
      "auth_info/*",
      "data/*"
    ]
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "@dataconnect/admin-generated": "file:src/dataconnect-admin-generated",
    "@google/generative-ai": "^0.24.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-stringify": "^6.4.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "@supabase/supabase-js": "^2.35.0",
    "firebase-admin": "^13.7.0",
    "firebase-functions": "^6.0.0",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^8.0.2",
    "pdfkit": "^0.17.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
